endpoint    = "http://localhost:4000/v1"
api_key     = ""
model       = "qwen3-235b"
timeout_sec = 30
token_limit = 8000

# Connector type: openai-qwen (default) | openai-json | bedrock
connector   = "openai-qwen"

# AWS Bedrock settings (only needed when connector = "bedrock")
# aws_region     = "us-east-1"
# aws_access_key = ""
# aws_secret_key = ""

# MCP servers config (optional — path to JSON file)
# mcp_config = "~/.config/ccl/mcp.json"

[permissions]                                                                                                                                                                                                                                                            
read   = true    # auto-approve: read_file, list_dir, search_files, file_info                                                                                                                                                                                            
write  = true    # auto-approve: write_file, edit_file, create_dir                                                                                                                                                                                                       
delete = false   # auto-approve: delete_file                                                                                                                                                                                                                             
shell  = false   # auto-approve: run_shell
